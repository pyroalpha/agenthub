# AgentHub Environment Configuration
# Copy this file to .env and fill in your values

# ===========================================
# LLM Provider Configuration
# ===========================================

# OpenAI (compatible with MiniMax, DeepSeek, etc.)
# OPENAI_API_KEY=sk-your-openai-key
# OPENAI_API_BASE=https://api.openai.com/v1

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-your-key
# ANTHROPIC_API_BASE=https://api.anthropic.com

# ===========================================
# Model Configuration
# ===========================================

# Default model for skill execution
# Format: "provider:model-name"
# Examples:
#   - "openai:gpt-4"
#   - "anthropic:claude-sonnet-4-6"
MODEL_NAME=anthropic:claude-sonnet-4-6

# ===========================================
# AgentHub Directory
# ===========================================

# Root directory for all agents
# Default: ~/.agenthub
# AGENTHUB_DIR=/path/to/agenthub

# ===========================================
# Built-in Skills Directory
# ===========================================

# Directory containing built-in skills
# Default: <package_dir>/agenthub/builtin_skills (auto-detected)
# BUILTIN_SKILLS_DIR=/path/to/skills

# ===========================================
# Timeouts (in seconds)
# ===========================================

# Default skill execution timeout
# DEFAULT_TIMEOUT=120

# Evolution skill timeout
# EVOLUTION_TIMEOUT=180

# Self-evolution timeout
# SELF_EVOLUTION_TIMEOUT=300

# Init agent timeout
# INIT_AGENT_TIMEOUT=120
